<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= song.song_name %> - Details</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #1db954;
            --bg: #121212;
            --card-bg: #181818;
            --text: #ffffff;
            --text-muted: #b3b3b3;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--text-muted);
            text-decoration: none;
            margin-bottom: 30px;
            padding: 10px 20px;
            border-radius: 24px;
            transition: all 0.3s;
            font-weight: 500;
            font-size: 1rem;
            background-color: rgba(255,255,255,0.05);
        }

        .back-link:hover {
            background-color: rgba(255,255,255,0.15);
            color: var(--text);
            transform: translateX(-4px);
        }

        .song-header {
            display: flex;
            gap: 40px;
            margin-bottom: 50px;
            background: linear-gradient(135deg, rgba(29,185,84,0.2) 0%, rgba(24,24,24,0.8) 100%);
            padding: 40px;
            border-radius: 16px;
            backdrop-filter: blur(10px);
        }

        .album-cover {
            flex-shrink: 0;
        }

        .album-cover img {
            width: 300px;
            height: 300px;
            object-fit: cover;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        .song-info {
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            flex: 1;
        }

        .song-info h1 {
            font-size: 3.5rem;
            margin-bottom: 16px;
            font-weight: 700;
            line-height: 1.1;
        }

        .song-info h2 {
            font-size: 1.8rem;
            color: var(--text-muted);
            font-weight: 400;
        }

        .content-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 30px;
        }

        .section {
            background-color: var(--card-bg);
            padding: 30px;
            border-radius: 12px;
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 20px;
            color: var(--primary);
        }

        .lyrics-content {
            line-height: 1.9;
            white-space: pre-line;
            font-size: 1.05rem;
            color: #e0e0e0;
        }

        .about-content {
            line-height: 1.7;
            color: var(--text-muted);
            margin-bottom: 25px;
        }

        .youtube-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: linear-gradient(135deg, #ff0000 0%, #cc0000 100%);
            color: white;
            padding: 14px 28px;
            border-radius: 30px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(255,0,0,0.3);
        }

        .youtube-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255,0,0,0.4);
        }

        .delete-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 30px;
            padding: 12px 24px;
            background-color: rgba(255,68,68,0.15);
            color: #ff4444;
            text-decoration: none;
            border-radius: 24px;
            font-weight: 600;
            transition: all 0.3s;
            border: 1px solid rgba(255,68,68,0.3);
        }

        .delete-link:hover {
            background-color: rgba(255,68,68,0.25);
            color: #ff6666;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(255,68,68,0.3);
        }

        .edit-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 30px;
            margin-right: 12px;
            padding: 12px 24px;
            background-color: rgba(29,185,84,0.15);
            color: var(--primary);
            text-decoration: none;
            border-radius: 24px;
            font-weight: 600;
            transition: all 0.3s;
            border: 1px solid rgba(29,185,84,0.3);
        }

        .edit-link:hover {
            background-color: rgba(29,185,84,0.25);
            color: #1ed760;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(29,185,84,0.3);
        }

        @media (max-width: 768px) {
            .song-header {
                flex-direction: column;
                text-align: center;
            }

            .album-cover img {
                width: 200px;
                height: 200px;
                margin: 0 auto;
            }

            .song-info h1 {
                font-size: 2rem;
            }

            .song-info h2 {
                font-size: 1.2rem;
            }

            .content-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <a href="/songs" class="back-link">← Back to Library</a>

        <div class="song-header">
            <div class="album-cover">
                <img src="<%= song.picture %>" alt="<%= song.song_name %>">
            </div>
            <div class="song-info">
                <h1><%= song.song_name %></h1>
                <h2><%= song.artist %></h2>
            </div>
        </div>

        <div class="content-grid">
            <div class="section">
                <div class="section-title">Lyrics</div>
                <div class="lyrics-content"><%= song.lyrics %></div>
            </div>

            <div class="section">
                <div class="section-title">About</div>
                <p class="about-content"><%= song.about %></p>
                <a href="<%= song.youtube_link %>" target="_blank" class="youtube-btn">
                    ▶ Watch on YouTube
                </a>
            </div>
        </div>
        <% if (isAdmin) { %>
            <div style="margin-top: 30px;">
                <a href="/songs/edit/<%= song._id %>" class="edit-link">✏️ Edit Song</a>
                <a href="/songs/delete/<%= song._id %>" class="delete-link" onclick="return confirm('Delete this song?')">🗑️ Delete</a>
            </div>
        <% } %>
    </div>
</body>
</html>