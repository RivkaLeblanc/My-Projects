<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Song Library</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #1db954;
            --bg: #121212;
            --card-bg: #181818;
            --text: #ffffff;
            --text-muted: #b3b3b3;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding: 30px 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .header h1 {
            font-size: 3rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--primary) 0%, #1ed760 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .add-button {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            background: linear-gradient(135deg, var(--primary) 0%, #1ed760 100%);
            color: white;
            text-decoration: none;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(29,185,84,0.3);
        }

        .add-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(29,185,84,0.4);
        }

        .songs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 24px;
        }

        .song-card {
            background-color: var(--card-bg);
            padding: 20px;
            border-radius: 12px;
            text-decoration: none;
            color: inherit;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .song-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(29,185,84,0.1) 0%, transparent 100%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .song-card:hover::before {
            opacity: 1;
        }

        .song-card:hover {
            background-color: #282828;
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.4);
        }

        .song-image {
            position: relative;
            margin-bottom: 16px;
            overflow: hidden;
            border-radius: 8px;
        }

        .song-image img {
            width: 100%;
            aspect-ratio: 1/1;
            object-fit: cover;
            display: block;
            transition: transform 0.3s ease;
        }

        .song-card:hover .song-image img {
            transform: scale(1.05);
        }

        .song-info {
            position: relative;
            z-index: 1;
        }

        .song-title {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 8px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .song-artist {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 12px;
        }

        .delete-link {
            display: inline-block;
            color: #ff4444;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            padding: 6px 12px;
            border-radius: 16px;
            transition: all 0.2s ease;
            background-color: rgba(255,68,68,0.1);
        }

        .delete-link:hover {
            background-color: rgba(255,68,68,0.2);
            color: #ff6666;
        }

        .edit-link {
            display: inline-block;
            color: var(--primary);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            padding: 6px 12px;
            border-radius: 16px;
            transition: all 0.2s ease;
            background-color: rgba(29,185,84,0.1);
            margin-left: 6px;
        }

        .edit-link:hover {
            background-color: rgba(29,185,84,0.2);
            color: #1ed760;
        }

        .action-buttons {
            display: flex;
            gap: 8px;
            margin-top: 8px;
        }

        .logout-button {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background-color: rgba(255,255,255,0.1);
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 24px;
            font-weight: 500;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

        .logout-button:hover {
            background-color: rgba(255,68,68,0.2);
            color: #ff6666;
        }

        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                gap: 20px;
                text-align: center;
            }

            .header h1 {
                font-size: 2rem;
            }

            .songs-grid {
                grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
                gap: 16px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🎵 Your Library</h1>
            <div style="display: flex; gap: 12px; align-items: center;">
                <% if (isAdmin) { %>
                <a href="/songs/addSong" class="add-button">+ Add New Song</a>
                <% } %>
                <a href="/logout" class="logout-button">🚪 Logout</a>
            </div>
        </div>
        
        <div class="songs-grid">
            <% songs.forEach(song => { %>
                <div class="song-card">
                    <a href="/songs/<%= song._id %>" style="text-decoration: none; color: inherit;">
                        <div class="song-image">
                            <img src="<%= song.picture %>" alt="<%= song.song_name %>">
                        </div>
                        <div class="song-info">
                            <div class="song-title"><%= song.song_name %></div>
                            <div class="song-artist"><%= song.artist %></div>
                        </div>
                    </a>
                    <% if (isAdmin) { %>
                    <div class="action-buttons">
                        <a href="/songs/edit/<%= song._id %>" class="edit-link">✏️ Edit</a>
                        <a href="/songs/delete/<%= song._id %>" class="delete-link" onclick="return confirm('Delete this song?')">🗑️ Delete</a>
                    </div>
                    <% } %>


                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>